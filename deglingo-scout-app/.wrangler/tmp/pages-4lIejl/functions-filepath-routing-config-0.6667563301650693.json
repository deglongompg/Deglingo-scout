{
  "routes": [
    {
      "routePath": "/api/sorare/cards",
      "mountPath": "/api/sorare",
      "method": "GET",
      "module": [
        "api/sorare/cards.js:onRequestGet"
      ]
    },
    {
      "routePath": "/api/sorare/cards",
      "mountPath": "/api/sorare",
      "method": "OPTIONS",
      "module": [
        "api/sorare/cards.js:onRequestOptions"
      ]
    },
    {
      "routePath": "/auth/sorare/callback",
      "mountPath": "/auth/sorare",
      "method": "GET",
      "module": [
        "auth/sorare/callback.js:onRequestGet"
      ]
    },
    {
      "routePath": "/auth/sorare/logout",
      "mountPath": "/auth/sorare",
      "method": "GET",
      "module": [
        "auth/sorare/logout.js:onRequestGet"
      ]
    }
  ],
  "baseURL": "/"
}